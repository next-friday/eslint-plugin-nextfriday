{
  "name": "eslint-plugin-nextfriday",
  "version": "1.21.0",
  "description": "A comprehensive ESLint plugin providing custom rules and configurations for Next Friday development workflows.",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "nextfriday",
    "next-friday",
    "linting",
    "code-quality",
    "javascript",
    "typescript",
    "development-tools"
  ],
  "homepage": "https://github.com/next-friday/eslint-plugin-nextfriday",
  "bugs": {
    "url": "https://github.com/next-friday/eslint-plugin-nextfriday/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/next-friday/eslint-plugin-nextfriday.git"
  },
  "license": "MIT",
  "author": "Next Friday <nextfriday.developer@gmail.com>",
  "contributors": [
    "@joetakara"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.cjs"
    }
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "docs",
    "lib"
  ],
  "scripts": {
    "build": "tsup",
    "changeset": "changeset",
    "changeset:publish": "npm publish --provenance --access public",
    "changeset:version": "changeset version",
    "clear": "rm -rf lib node_modules/.cache .eslintcache",
    "eslint": "eslint src --ext .js,.ts --fix",
    "eslint:check": "eslint src --ext .js,.ts",
    "prepare": "husky",
    "prepublishOnly": "pnpm build",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "sort-package-json": "pnpm exec sort-package-json",
    "sort-package-json:check": "pnpm exec sort-package-json --check",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.58.1",
    "emoji-regex": "^10.6.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "tsup": "^8.5.1"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^30.3.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/core": "^1.15.24",
    "@swc/jest": "^0.2.39",
    "@types/eslint": "^9.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/ramda": "^0.31.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@typescript-eslint/rule-tester": "^8.58.1",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-extended": "^3.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "sort-package-json": "^3.6.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
